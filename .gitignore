# Large source files (PDFs, ebooks)
archive/
inbox/
batch_qa_intake/

# Kokoro model files (downloaded by scripts/install-kokoro.ps1, not tracked)
tools/kokoro-models/

# Generated output
output/

# Intermediate processing files
processing/

# Ebook formats (binary, large)
*.pdf
*.epub
*.mobi
*.azw3
*.kfx
# Exception: synthetic test fixtures committed as regression anchors
!web_service/test-pdfs/*.pdf

# Audio files
*.mp3
*.wav

# Python
__pycache__/
*.pyc

# Environment
.env
.env.local
.env.production
**/secrets/

# Logs
*.log
logs/**
!logs/chapter-detect-failures/
!logs/chapter-detect-failures/.gitkeep

# Debug output
debug/
debug-*/
debug_paragraphs.txt

# Binary tools (download separately)
tools/balcon/
tools/poppler/

# Per-machine setup-script artifacts (registry backups from voice bridge / aliases)
tools/setup/*.reg

# Credentials and session data
tools/data/foh_credentials.json
tools/data/foh_session.json

# Pattern database (local run data)
data/ebook_patterns.db

# PR screenshot artifacts (captured locally, not committed)
.screenshots/
data/covers/

# Pipeline cache (local run data)
tools/data/pipeline_cache.db

# VQA pre-274 baselines (legacy PDF-sourced, uncontrolled — not reproducible)
data/vqa_baseline_pre_274/
# data/vqa_baseline_post_274/ — tracked; standardized to KFX→Calibre source (SCRUM-282)

# SCRUM smoke-test output (regenerable; cross-provider + sb-chat evolution drift)
data/scrum*_smoke*/
data/scrum*_6book/
# Broader SCRUM-28x evidence-data catch-all (keeps top-level *.json summaries trackable)
data/scrum28?_*/

# Local Claude settings (user-specific permissions)
.claude/settings.local.json
.claude/preflight.md
.claude/preflight.tmp.md

# Test corpus (books are copyrighted, but baselines/expectations are committed)
test-corpus/*
!test-corpus/README.md
!test-corpus/*.baseline.json
!test-corpus/*.expect.json

# Git worktrees (INFRA-71)
.worktrees/
.claude/worktrees/

# Review agent context directories (generated, not source)
.context/

# Vercel CLI link directory (project IDs are stored here)
.vercel

# Playwright MCP runtime artifacts (console + page captures)
.playwright-mcp/

# Cloudflare Worker local dev secrets (real secrets go through wrangler secret put)
cloudflare/contact-worker/.dev.vars

# EB-233 visual baselines (binary PNGs + Lighthouse JSON — gitignored; MANIFEST.md and .gitkeep committed)
web_service/frontend/.baselines/**
!web_service/frontend/.baselines/.gitkeep
!web_service/frontend/.baselines/eb233-pre/
!web_service/frontend/.baselines/eb233-pre/MANIFEST.md
!web_service/frontend/.baselines/eb233-post/
!web_service/frontend/.baselines/eb233-post/MANIFEST.md
