# Large source files (PDFs, ebooks)
archive/
inbox/
batch_qa_intake/

# Generated output
output/

# Intermediate processing files
processing/

# Ebook formats (binary, large)
*.pdf
*.epub
*.mobi
*.azw3
*.kfx

# Audio files
*.mp3
*.wav

# Python
__pycache__/
*.pyc

# Environment
.env
.env.local
.env.production
**/secrets/

# Logs
*.log
logs/

# Debug output
debug/
debug-*/
debug_paragraphs.txt

# Binary tools (download separately)
tools/balcon/
tools/poppler/

# Credentials and session data
tools/data/foh_credentials.json
tools/data/foh_session.json

# Pattern database (local run data)
data/ebook_patterns.db
data/covers/

# Pipeline cache (local run data)
tools/data/pipeline_cache.db

# VQA pre-274 baselines (legacy PDF-sourced, uncontrolled — not reproducible)
data/vqa_baseline_pre_274/
# data/vqa_baseline_post_274/ — tracked; standardized to KFX→Calibre source (SCRUM-282)

# SCRUM smoke-test output (regenerable; cross-provider + sb-chat evolution drift)
data/scrum*_smoke*/
data/scrum*_6book/
# Broader SCRUM-28x evidence-data catch-all (keeps top-level *.json summaries trackable)
data/scrum28?_*/

# Local Claude settings (user-specific permissions)
.claude/settings.local.json

# Test corpus (books are copyrighted, but baselines/expectations are committed)
test-corpus/*
!test-corpus/README.md
!test-corpus/*.baseline.json
!test-corpus/*.expect.json

# Git worktrees (INFRA-71)
.worktrees/

# Review agent context directories (generated, not source)
.context/
