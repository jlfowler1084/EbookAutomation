  },
  "kokoro": {
    "model_dir": "tools/kokoro-models"
  },
  "kindle_delivery": {
    "calibre_library": "/home/joe/calibre-library"
  },
  "tts": {
    "enabled": false
  },
  "mp3": {
    "enabled": false
  },
  "kindle": {
