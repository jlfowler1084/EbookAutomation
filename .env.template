# EbookAutomation — required environment variables
# Copy to .env, fill in values, then: chmod 600 .env
# The .env file is gitignored — never commit real keys.

# OpenRouter API key (used by CloudVLProvider / visual_qa.py --provider openrouter)
# Default VM provider: qwen/qwen3-vl-30b-a3b-instruct
OPENROUTER_API_KEY=

# Anthropic API key (used by ClaudeVisionProvider / visual_qa.py --provider claude)
ANTHROPIC_API_KEY=

# Google Gemini API key (used by gemini_ocr.py for scanned-page OCR fallback)
GOOGLE_API_KEY=
