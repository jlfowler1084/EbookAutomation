{
  "permissions": {
    "deny": [
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Supabase__*",
      "mcp__claude_ai_Indeed__*",
      "mcp__claude_ai_Dice__*",
      "mcp__claude_ai_Microsoft_Learn__*"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File tools/hooks/post-edit-test.ps1",
            "timeout": 120,
            "statusMessage": "Running quick regression tests..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "playwright@claude-plugins-official": false,
    "context7@claude-plugins-official": false,
    "github@claude-plugins-official": false
  }
}
