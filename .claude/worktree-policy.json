{
  "version": 1,
  "protected_branches": ["master"],
  "worktree_pattern": "worktree/<TICKET>-<slug>",
  "worktree_root": ".worktrees/",
  "allow_bypass_env": "ALLOW_MAIN_COMMIT",
  "allow_bypass_push_env": "ALLOW_MAIN_PUSH",
  "exempt_paths": [
    "data/batch_reports/**",
    "data/debug/**",
    "prompts/**",
    "docs/**",
    ".claude/**",
    "CLAUDE.md",
    "QWEN.md",
    "README.md",
    "feature-manifest.json",
    "requirements.txt",
    "dev-requirements.txt",
    "settings.json",
    "config/settings.json",
    ".mcp.json",
    ".gitignore"
  ]
}
